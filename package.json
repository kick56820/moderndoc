{
  "name": "pbdocs-node",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone PowerBuilder 10.5 Help browser.",
  "scripts": {
    "start": "node server.js",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "ui:build": "node scripts/build-bootstrap-assets.js",
    "check": "node scripts/release-check.js",
    "release:check": "node scripts/release-check.js",
    "release:package": "node scripts/package-release.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "express": "^4.22.1"
  }
}
